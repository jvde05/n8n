{% extends 'layout.twig' %}
{% block title %}{{ meta_title }}{% endblock %}
{% block description %}{{ meta_desc }}{% endblock %}

{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "{{ heading }}",
  "areaServed": "{{ district.name }}, İstanbul",
  "provider": {
    "@type": "AutoRepair",
    "name": "{{ site.brand_name|default('Çözüm Oto Elektrik') }}",
    "telephone": "{{ site.phone_primary }}",
    "address": "{{ site.address }}"
  }
}
</script>
{% endblock %}

{% block content %}
<section class="page-head">
    <div class="container">
        <nav class="breadcrumb">
            <a href="/">Anasayfa</a> / <a href="/hizmetler">Hizmetler</a> /
            <a href="/hizmet/{{ service.slug }}">{{ service.title }}</a> / <span>{{ district.name }}</span>
        </nav>
        <h1>{{ heading }}</h1>
    </div>
</section>

<section class="section">
    <div class="container content-layout">
        <article class="content">
            <div class="prose">{{ body|raw }}</div>

            <div class="content__cta">
                {% if site.whatsapp %}<a class="btn btn--primary" href="{{ whatsapp_link('Merhaba, ' ~ heading ~ ' için bilgi almak istiyorum.') }}" target="_blank" rel="noopener">WhatsApp'tan Sor</a>{% endif %}
                {% if site.phone_primary %}<a class="btn btn--ghost" href="{{ tel_link(site.phone_primary) }}">{{ site.phone_primary }}</a>{% endif %}
            </div>

            {% if faqs|length %}
            <div class="faq">
                <h2>Sıkça Sorulan Sorular</h2>
                {% for f in faqs %}
                <details class="faq__item"><summary>{{ f.question }}</summary><div class="faq__body">{{ f.answer|nl2br }}</div></details>
                {% endfor %}
            </div>
            {% endif %}
        </article>

        <aside class="sidebar">
            <div class="sidebar__box">
                <h3>Diğer Bölgeler</h3>
                <ul class="district-list">
                    {% for d in districts %}
                    <li{% if d.id == district.id %} class="is-active"{% endif %}>
                        <a href="/hizmet/{{ service.slug }}/{{ d.slug }}">{{ d.name }}</a>
                    </li>
                    {% endfor %}
                </ul>
            </div>
            <div class="sidebar__box sidebar__box--accent">
                <h3>Hızlı İletişim</h3>
                {% if site.phone_primary %}<a class="sidebar__phone" href="{{ tel_link(site.phone_primary) }}">{{ site.phone_primary }}</a>{% endif %}
                {% if site.address %}<p>{{ site.address }}</p>{% endif %}
            </div>
        </aside>
    </div>
</section>
{% endblock %}
