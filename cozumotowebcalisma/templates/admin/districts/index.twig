{% extends 'admin/layout.twig' %}
{% set current_nav = 'districts' %}
{% block title %}İlçeler{% endblock %}

{% block content %}
<div class="adm-card">
    <div class="adm-card__head">
        <h2>İlçeler ({{ districts|length }})</h2>
        <a class="adm-btn adm-btn--primary" href="/yonetim/ilceler/yeni">+ Yeni İlçe</a>
    </div>
    <p class="adm-hint">Eklenen her aktif ilçe, ilçe sayfaları açık olan tüm hizmetler için otomatik landing sayfası oluşturur.</p>
    <table class="adm-table">
        <thead><tr><th>Sıra</th><th>İlçe</th><th>Slug</th><th>Durum</th><th></th></tr></thead>
        <tbody>
        {% for d in districts %}
        <tr>
            <td>{{ d.sort_order }}</td>
            <td><strong>{{ d.name }}</strong></td>
            <td><code>{{ d.slug }}</code></td>
            <td>{% if d.is_active %}<span class="adm-badge adm-badge--on">Aktif</span>{% else %}<span class="adm-badge">Pasif</span>{% endif %}</td>
            <td class="adm-actions">
                <a class="adm-link" href="/yonetim/ilceler/{{ d.id }}/duzenle">Düzenle</a>
                <form method="post" action="/yonetim/ilceler/{{ d.id }}/sil" data-confirm="Bu ilçeyi silmek istediğinize emin misiniz?">
                    <input type="hidden" name="_csrf" value="{{ csrf }}">
                    <button class="adm-link adm-link--danger">Sil</button>
                </form>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="5" class="adm-empty">Henüz ilçe eklenmemiş.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
