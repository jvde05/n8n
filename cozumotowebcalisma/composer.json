{
    "name": "cozumoto/web",
    "description": "Çözüm Oto Elektrik - Renault Elektronik Servisi kurumsal web sitesi ve yönetim paneli",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "slim/twig-view": "^3.3",
        "twig/twig": "^3.8",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public",
        "migrate": "php database/migrate.php",
        "seed": "php database/seed.php"
    },
    "config": {
        "sort-packages": true
    }
}
