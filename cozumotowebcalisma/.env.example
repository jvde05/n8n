# Uygulama
APP_NAME="Çözüm Oto Elektrik"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://www.renaultelektronikservisi.com.tr

# Veritabanı sürücüsü: mysql | sqlite
DB_DRIVER=mysql

# MySQL (production / paylaşımlı hosting)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cozumoto
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# SQLite (lokal geliştirme) — DB_DRIVER=sqlite olduğunda kullanılır
DB_SQLITE_PATH=database/cozumoto.sqlite

# İlk yönetici hesabı (seed sırasında oluşturulur)
ADMIN_NAME="Site Yöneticisi"
ADMIN_EMAIL=admin@cozumoto.local
ADMIN_PASSWORD=Degistir123!

# Oturum
SESSION_NAME=cozumoto_session
