# Bu dosyayi ".env" olarak kopyala ve doldur:  cp .env.example .env

# Claude (senaryo/baslik/etiket uretimi) - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Pexels (ucretsiz dikey stok video) - https://www.pexels.com/api/
PEXELS_API_KEY=xxxxxxxxxxxxxxxx

# edge-tts sesi (ucretsiz). Turkce icin: tr-TR-EmelNeural veya tr-TR-AhmetNeural
# Ingilizce icin: en-US-AriaNeural / en-US-GuyNeural
TTS_VOICE=en-US-AriaNeural

# Sunucu ayarlari
TZ=Europe/Istanbul
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
