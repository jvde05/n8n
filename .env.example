# Bu dosyayi ".env" olarak kopyala ve doldur:  cp .env.example .env

# Claude (senaryo/baslik/etiket uretimi) - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Pexels (ucretsiz dikey stok video) - https://www.pexels.com/api/
PEXELS_API_KEY=xxxxxxxxxxxxxxxx

# edge-tts sesi (ucretsiz). Turkce icin: tr-TR-EmelNeural veya tr-TR-AhmetNeural
# Ingilizce icin: en-US-AriaNeural / en-US-GuyNeural
TTS_VOICE=en-US-AriaNeural

# --- Native yukleme + analytics (standalone / Faz 2-3 icin; n8n kullaniyorsan opsiyonel) ---
# YouTube Data API OAuth (refresh token akisi). Kanal bazli icin: ACOS_<KANAL>_YT_...
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
# TikTok Content Posting API (onayli app gerekir)
TT_ACCESS_TOKEN=
# Instagram Graph API (Business hesap + public video URL gerekir)
IG_USER_ID=
IG_ACCESS_TOKEN=

# Self-learning veritabani / insights (varsayilanlar yeterli)
ACOS_DB=/data/acos.db
ACOS_INSIGHTS_DIR=/data/insights

# Sunucu ayarlari
TZ=Europe/Istanbul
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
